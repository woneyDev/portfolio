# ================================================================
# 환경변수 템플릿 — 실제 값은 절대 이 파일에 적지 마십시오.
# 이 파일을 복사해서 .env 를 만들고 값을 채우세요.
# .env 파일은 .gitignore 에 등록되어 있어 GitHub에 올라가지 않습니다.
# ================================================================

# ── Frontend ──────────────────────────────────────────────────
# GitHub Pages 배포 시: VITE_BASE_PATH=/portfolio/
# Docker 로컬 실행 시: 이 줄을 비워두세요 (자동으로 '/' 사용)
VITE_BASE_PATH=

# 주소에 "#"가 붙는 해시 라우팅은 GitHub Pages 전용이다. Docker로 띄우는 환경(로컬 개발 포함,
# VPS 운영도 동일)은 항상 browser로 두어 "#" 없는 깨끗한 주소를 쓴다 — 비워두면 기본값이 hash라서
# 반드시 아래처럼 명시해야 한다.
VITE_ROUTER_MODE=browser

# 화면이 API 서버를 찾아갈 주소. 비워두면 http://localhost:8081 사용(로컬 개발 기본값).
# VPS/운영 배포 시에는 그 서버의 실제 주소(IP 또는 도메인)로 반드시 채워야 함 —
# 안 채우면 방문자 브라우저가 "localhost"(방문자 자신의 컴퓨터)로 요청을 보내게 되어 전부 실패함.
VITE_API_URL=

# ── Java API (로컬 Docker 환경) ────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/portfolio
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ── Java API (AWS 환경으로 전환 시 아래로 교체) ──────────────────
# SPRING_DATASOURCE_URL=jdbc:postgresql://{RDS_ENDPOINT}:5432/portfolio
# SPRING_DATASOURCE_USERNAME=your_rds_username
# SPRING_DATASOURCE_PASSWORD=your_rds_password
# SPRING_REDIS_HOST={ELASTICACHE_ENDPOINT}
# SPRING_REDIS_PORT=6379

# ── PostgreSQL (로컬 Docker 컨테이너용) ──────────────────────────
POSTGRES_DB=portfolio
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password

# ── Java API 관리자 계정 (Flyway가 첫 회원(member #1)을 만들 때 사용) ──
ADMIN_PASSWORD=your_admin_password
MEMBER_ONE_USERNAME=your_username
VITE_MEMBER_ONE_USERNAME=your_username

# 로그인/마이페이지 접속 허용 IP 목록은 더 이상 .env가 아니라 DB(admin_allowed_ip 테이블)에서
# 관리한다. 로그인 후 마이페이지의 "접속 허용 IP 관리" 화면에서 추가/삭제하면 즉시 반영된다.
# (localhost는 이 목록과 무관하게 항상 허용)

# ── 이메일 발송 (회원가입 인증 메일 — Gmail 앱 비밀번호 사용) ──────
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_APP_PASSWORD=your_gmail_app_password

# ── 인증 메일 링크에 사용할 프론트엔드 주소 ────────────────────────
# Docker 로컬 실행 시: http://localhost:8080
# GitHub Pages 배포 시: https://woneydev.github.io/portfolio
FRONTEND_URL=http://localhost:8080

# ── 소셜 로그인 (각 개발자 콘솔에서 앱 등록 후 발급받은 값을 입력) ──
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8081/api/auth/oauth/google/callback

# Kakao Developers: https://developers.kakao.com
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8081/api/auth/oauth/kakao/callback

# Naver Developers: https://developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8081/api/auth/oauth/naver/callback

# ── Python Data Service ────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
REDIS_HOST=redis
REDIS_PORT=6379
